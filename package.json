{
    "name": "colabbridge",
    "version": "2.1.0",
    "description": "A REST API wrapper around Google Colab CLI that enables remote execution of Python code on Colab VMs",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest",
        "lint": "eslint server.js",
        "clean": "rm -rf node_modules package-lock.json && npm install",
        "doctor": "node -e \"console.log('Node:', process.version, 'Memory:', Math.round(process.memoryUsage().rss / 1024 / 1024), 'MB')\""
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.1"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "colab",
        "google-colab",
        "orchestrator",
        "api",
        "backend",
        "render",
        "express",
        "colab-bridge",
        "gpu",
        "tpu",
        "machine-learning"
    ],
    "author": "Kushal Kumar J",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/kushalkumarj2006/colabbridge"
    },
    "bugs": {
        "url": "https://github.com/kushalkumarj2006/colabbridge/issues"
    },
    "homepage": "https://github.com/kushalkumarj2006/colabbridge#readme"
}
